# Read CSV file
df = spark.read.format("csv") \
    .option("header", "true") \
    .option("inferSchema", "false") \
    .load("customers-100.csv")   # Make sure path is correct
 
#select specific columns

df_select = df.select(col("Customer Id"), col("First Name"), col("Last Name"), col("Email")).show()

#alies name columns

df_alias = df.select(col("First Name").alias("FName")).show()
